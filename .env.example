# Variables de Entorno para el Chatbot UASD

# Agrega tu API Key de Gemini aquí para que la app funcione localmente.
# Puedes obtenerla en: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=tu_api_key_de_gemini_aqui

# Agrega tu API Key de Groq aquí para experimentar con modelos de Llama.
# Puedes obtenerla en: https://console.groq.com/
VITE_GROQ_API_KEY=tu_api_key_de_groq_aqui
VITE_GROQ_MODEL=llama-3.3-70b-versatile

